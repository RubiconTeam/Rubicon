; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Rubicon"
config/version="v1.0.0"
run/main_scene="uid://cuuuxjlonwxhn"
config/use_custom_user_dir=true
config/features=PackedStringArray("4.4", "C#", "Forward Plus")
run/max_fps=240
run/delta_smoothing=false
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/fullsize=false
boot_splash/use_filter=false
config/icon="uid://dhvjpq5u6n18h"

[audio]

buses/default_bus_layout="uid://8f826qwop1rs"

[autoload]

UserSettings="*res://addons/PukiTools.GodotSharp/UserSettingsInstance.cs"
RubiconEngine="*res://source/Rubicon/RubiconEngineInstance.cs"
Conductor="*res://addons/Rubicon.Core/source/ConductorInstance.cs"
ScreenManager="*res://addons/PukiTools.GodotSharp/Screens/ScreenManagerInstance.cs"
StoryMode="*res://source/Rubicon/Story/StoryModeInstance.cs"
RubiconGame="*res://source/Rubicon/Game/RubiconGameInstance.cs"
AudioManager="*res://addons/PukiTools.GodotSharp/Audio/AudioManagerInstance.cs"
RubiconCore="*res://addons/Rubicon.Core/source/RubiconCoreInstance.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/sharp_corners=true
window/size/window_width_override=1366
window/size/window_height_override=768
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Rubicon"

[editor_plugins]

enabled=PackedStringArray("res://addons/PukiTools.GodotSharp/plugin.cfg", "res://addons/gdanimate/plugin.cfg", "res://addons/rubichart_converter/plugin.cfg", "res://addons/rubichart_importer/plugin.cfg", "res://addons/rubicon_helper/plugin.cfg", "res://addons/sprite_importer/plugin.cfg")

[file_customization]

folder_colors={
"res://source/Rubicon/Core/": "orange",
"res://source/Rubicon/Core/Autoload/": "green",
"res://source/Rubicon/Rulesets/Mania/": "teal"
}

[global_group]

Engine/Settings="[Engine-Related] Related to the SettingsManager class."

[gui]

fonts/dynamic_fonts/use_oversampling=false

[importer_defaults]

texture={
&"compress/channel_pack": 1,
&"compress/hdr_compression": 0,
&"compress/high_quality": true,
&"compress/normal_map": 2,
&"roughness/mode": 1
}

