[input_devices]

buffering/agile_event_flushing=true

[rendering]

textures/vram_compression/import_etc2_astc=true

[rubicon]

general/default_ui_style="Funkin"
rulesets/default_ruleset="Mania"
rulesets/mania/default_note_skin="Funkin"
judgments/perfect_hit_window=15.0
judgments/great_hit_window=25.0
judgments/good_hit_window=50.0
judgments/okay_hit_window=90.0
judgments/bad_hit_window=135.0
general/settings_save_path="user://settings.cfg"
bindings/customizable=PackedStringArray("MANIA_4K_0", "MANIA_4K_1", "MANIA_4K_2", "MANIA_4K_3", "GAME_PAUSE", "DEBUG_INFO", "VOL_UP", "VOL_DOWN", "VOL_MUTE")
general/fallback/song="Sew"
general/fallback/difficulty="Normal"
general/fallback/stage_2d="Stage"
general/fallback/stage_3d=""
general/fallback/character_2d="Bf"
general/fallback/character_3d=""
general/minimum_aspect_ratio=1.333
general/maximum_aspect_ratio=1.778
