[input_devices]

buffering/agile_event_flushing=true

[puki_tools]

general/settings_path="user://settings.cfg"

[rendering]

textures/vram_compression/import_etc2_astc=true

[rubicon]

general/default_ui_style="Funkin"
rulesets/default_ruleset="Mania"
judgments/perfect_hit_window=20.0
judgments/great_hit_window=45.0
judgments/good_hit_window=75.0
judgments/okay_hit_window=105.0
judgments/bad_hit_window=130.0
bindings/customizable=PackedStringArray("MANIA_4K_0", "MANIA_4K_1", "MANIA_4K_2", "MANIA_4K_3", "GAME_PAUSE", "DEBUG_INFO", "VOL_UP", "VOL_DOWN", "VOL_MUTE")
general/fallback/song="test"
general/fallback/difficulty="Normal"
general/fallback/stage_2d="Stage"
general/fallback/stage_3d="Stage3D"
general/fallback/character_2d="Bf"
general/fallback/character_3d="Bf3D"
general/minimum_aspect_ratio=1.333
general/maximum_aspect_ratio=1.85
general/starting_window_size=Vector2i(1366, 768)
general/verbose=true
general/resources_folder="res://resources"
general/songs_folder="res://songs"
rulesets/mania/default_note_skin="funkin"
